<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_import_sales_wizard_form" model="ir.ui.view">
        <field name="name">import.sales.wizard.form</field>
        <field name="model">import.sales.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Ventas">
                <group>
                    <field name="file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>

                <footer>
                    <button name="action_import"
                            string="Importar"
                            type="object"
                            class="btn-primary"/>

                    <button string="Cancelar"
                            special="cancel"/>
                </footer>

            </form>
        </field>
    </record>

</odoo>